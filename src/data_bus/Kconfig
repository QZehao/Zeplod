menu "Data Bus (Standard)"

config DATA_BUS
    bool "Enable Data Bus module"
    default n
    help
      Named-channel, reference-counted stream data sharing.
      Completely independent from the event system.

config DATA_BUS_CHANNEL_NAME_MAX
    int "Maximum channel name length (including NUL terminator)"
    default 16
    range 8 64
    depends on DATA_BUS
    help
      Name buffer size used in channel creation, lookup, and
      event bridge notifications.
      Must match data_bus_event_notification_t::channel_name array size.

config DATA_BUS_MAX_CHANNELS
    int "Maximum number of channels"
    default 8
    range 1 64
    depends on DATA_BUS

config DATA_BUS_MAX_CONSUMERS_PER_CHANNEL
    int "Maximum consumers per channel"
    default 4
    range 1 32
    depends on DATA_BUS

config DATA_BUS_CHANNEL_QUEUE_DEPTH
    int "Channel queue depth (block pointer count)"
    default 16
    range 1 256
    depends on DATA_BUS

config DATA_BUS_MAX_BLOCKS
    int "Maximum concurrent blocks (data_bus_block_t slab size)"
    default 32
    range 1 256
    depends on DATA_BUS
    help
      Maximum number of data_bus_block_t structures in the system
      at any time. Should be >= total count of all data slab blocks
      to cover both slab and k_malloc fallback scenarios.

config DATA_BUS_DISPATCHER_STACK_SIZE
    int "Dispatcher thread stack size"
    default 2048
    range 512 8192
    depends on DATA_BUS

config DATA_BUS_DISPATCHER_PRIORITY
    int "Dispatcher thread priority"
    default 5
    range 0 15
    depends on DATA_BUS

config DATA_BUS_DEINIT_DRAIN_TIMEOUT_MS
    int "Deinit channel operation drain timeout (ms)"
    default 5000
    range 10 60000
    depends on DATA_BUS
    help
      Maximum time data_bus_deinit() waits for publishers, dispatcher work,
      and consumer unregister operations after the dispatcher thread exits.
      A timeout returns -EBUSY and leaves the bus shutting down so deinit can
      be retried without accepting new publishes.

config DATA_BUS_SLAB_ENABLE
    bool "Enable data bus slab pool"
    default y
    depends on DATA_BUS

config DATA_BUS_NO_MALLOC
    bool "Disallow k_malloc fallback for data buffers"
    default n
    depends on DATA_BUS && DATA_BUS_SLAB_ENABLE
    help
      When enabled, thread-context allocation behaves like the ISR path:
      slab exhaustion returns NULL and publish returns -ENOMEM.
      Recommended for hard real-time robot/motor control profiles.

config DATA_BUS_SLAB_64_COUNT
    int "64-byte slab block count"
    default 0
    range 0 256
    depends on DATA_BUS_SLAB_ENABLE

config DATA_BUS_SLAB_128_COUNT
    int "128-byte slab block count"
    default 0
    range 0 256
    depends on DATA_BUS_SLAB_ENABLE

config DATA_BUS_SLAB_256_COUNT
    int "256-byte slab block count"
    default 8
    range 0 256
    depends on DATA_BUS_SLAB_ENABLE

config DATA_BUS_SLAB_1K_COUNT
    int "1KB slab block count"
    default 4
    range 0 256
    depends on DATA_BUS_SLAB_ENABLE

config DATA_BUS_SLAB_512_COUNT
    int "512-byte slab block count"
    default 0
    range 0 256
    depends on DATA_BUS_SLAB_ENABLE

config DATA_BUS_SLAB_4K_COUNT
    int "4KB slab block count"
    default 2
    range 0 256
    depends on DATA_BUS_SLAB_ENABLE

config DATA_BUS_EVENT_BRIDGE
    bool "Bridge data bus notifications to event system"
    default y
    depends on DATA_BUS && EVENT_SYSTEM

config DATA_BUS_EVENT_TYPE_ID
    int "Event type ID for DATA_BUS_AVAILABLE bridge notifications"
    default 30
    range 0 255
    depends on DATA_BUS_EVENT_BRIDGE
    help
      Passed to event_publish_copy() from data_bus_event_bridge_notify().
      Must not collide with other application event types.

config DATA_BUS_FALLBACK_WARN_THRESHOLD
    int "k_malloc fallback warning threshold"
    default 0
    range 0 65535
    depends on DATA_BUS
    help
      Publish a Data Bus memory health warning after this many k_malloc
      fallback allocations on a channel. 0 disables event warning emission
      and preserves the existing logging-only behavior.

config DATA_BUS_HEALTH_EVENT_TYPE_ID
    int "Event type ID for Data Bus memory health warnings"
    default 31
    range 0 255
    depends on DATA_BUS_EVENT_BRIDGE && DATA_BUS_FALLBACK_WARN_THRESHOLD > 0
    help
      Passed to event_publish_copy() for DATA_BUS_MEMORY_WARNING events.
      Keep distinct from CONFIG_DATA_BUS_EVENT_TYPE_ID and application
      event type IDs.

config DATA_BUS_DEBUG_REFCNT
    bool "Debug: reference count assertions in destroy/deinit"
    default n
    depends on DATA_BUS
    help
      Check abnormal ref_count during channel_destroy and deinit
      to help locate unpaired release causing slab exhaustion.

config DATA_BUS_LOG_LEVEL
    int "Log level"
    default 3
    range 0 4
    depends on DATA_BUS
    help
      0=OFF, 1=ERROR, 2=WARNING, 3=INFO, 4=DEBUG
      Set to 0 or 1 for production to reduce code size.

endmenu
