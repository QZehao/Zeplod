menuconfig OTA_MODULE
	bool "Enable OTA module"
	default n
	depends on EVENT_MAX_TYPES > 51
	help
	  Firmware OTA state machine with pluggable ingest paths.
	  Requires CONFIG_EVENT_MAX_TYPES > 51 (event IDs 50-51).

if OTA_MODULE

config OTA_MODULE_AUTOINIT
	bool "Auto-register OTA module at boot (SYS_INIT)"
	default y
	help
	  Register ota_module via module_manager at APP_INIT_PRIO_MODULE_OTA.
	  Disable for unit tests that call ota_module_init() manually.

config OTA_MODULE_STACK_SIZE
	int "OTA worker stack size (reserved)"
	default 2048
	range 1024 8192

config OTA_MODULE_PRIORITY
	int "OTA worker thread priority (reserved)"
	default 7
	range 1 15

config OTA_TRANSPORT_NULL
	bool "Null (RAM) transport for ztest / native_sim only"
	default n
	help
	  Exclusive test mode using in-RAM simulated image. Disables product
	  ingest options below.

if !OTA_TRANSPORT_NULL

config OTA_TRANSPORT_MCUMGR_SMP
	bool "MCUmgr SMP passive ingest (primary product path)"
	default y
	depends on MCUMGR && IMG_MANAGER
	help
	  External mcumgr client pushes firmware via Zephyr img_mgmt.
	  Enable one or more MCUMGR_TRANSPORT_* (UART, BLE, UDP) in conf.
	  See conf/targets/mcumgr_smp.conf.

config OTA_TRANSPORT_ACTIVE
	bool "Active write_chunk ingest (custom protocol extension)"
	default n
	depends on IMG_MANAGER
	help
	  Enables ota_module_begin_update/write_chunk/finish using MCUboot
	  flash_img backend. For Modbus, HTTP, or other self-built transports.
	  May be combined with OTA_TRANSPORT_MCUMGR_SMP; only one ingest
	  session may run at a time (enforced at runtime).

endif

config OTA_NULL_TRANSPORT_BUF_SIZE
	int "Null transport simulated image size (bytes)"
	default 4096
	depends on OTA_TRANSPORT_NULL
	help
	  Size of in-RAM image buffer for native_sim tests.

config OTA_EXPECTED_IMAGE_SIZE
	int "Expected max OTA image size (progress denominator)"
	default 4096 if OTA_TRANSPORT_NULL
	default 524288 if OTA_TRANSPORT_ACTIVE
	default 524288 if OTA_TRANSPORT_MCUMGR_SMP
	help
	  Used to compute download percent when transport has no fixed capacity.

endif
