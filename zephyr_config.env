# Zephyr 本地路径配置（使用中）
# 编辑此文件，填入您的本地路径

# =============================================================================
# Zephyr SDK 配置
# =============================================================================
ZEPHYR_SDK_INSTALL_DIR=D:\Code\1-github-code\zephyr-sdk-0.17.2

# =============================================================================
# Zephyr 基础配置
# =============================================================================
ZEPHYR_BASE=D:\Code\1-github-code\zephyrproject\zephyr

# =============================================================================
# 虚拟环境配置
# =============================================================================
# Zephyr west 虚拟环境激活脚本路径（可选）
# 如果 west 安装在虚拟环境中，取消注释并填写路径
VIRTUAL_ENV_PATH=D:\Code\1-github-code\zephyrproject\.venv

# =============================================================================
# QEMU 仿真（Windows winget 默认安装路径）
# =============================================================================
# west build -t run 在 CMake 配置阶段解析 QEMU，需在此指定或加入系统 PATH
QEMU_BIN_PATH=C:/Program Files/qemu

# =============================================================================
# 构建配置
# =============================================================================
DEFAULT_BOARD=nucleo_l4r5zi
BUILD_DIR=build
