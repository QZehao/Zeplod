# Zeplod — Zephyr 嵌入式项目的 clangd 配置
# 解决 clangd 与 arm-zephyr-eabi-gcc 交叉编译器的兼容性问题

---
# 移除 compile_commands.json 中 GCC 特有的、clangd 不支持的标志
CompileFlags:
  Remove:
    # 链接器/库相关
    - -specs=*
    - -T*
    - -Wl,*
    - -Xlinker
    - -nostdlib
    - -nodefaultlibs
    # GCC 特有的编译标志
    - -fmacro-prefix-map=*
    - -fno-printf-return-value
    - -fno-defer-pop
    - -fno-reorder-functions
    - -fno-asynchronous-unwind-tables
    - -ftls-model=*
    - --param=*
    - -ffunction-sections
    - -fdata-sections
    - -fno-common
    # ARM/GCC 特有的警告标志（clangd 不支持的部分）
    - -Wexpansion-to-defined
    - -Wno-format-zero-length
    - -Wno-unused-but-set-variable
    - -Werror=implicit-int
    # 其他 GCC 特有选项
    - -fdiagnostics-color=*
    - -gdwarf-*
    - -mtp=*
    - -mfp16-format=*
    - -mabi=*
    # sysroot 相关（clangd 自己处理标准库路径）
    - --sysroot=*
  Add:
    # 告诉 clangd 目标是 ARM Cortex-M（避免主机 x86_64 的假设）
    - --target=arm-none-eabi
    # 定义 Zephyr 相关宏（如果 compile_commands.json 中缺失）
    - -D__ZEPHYR__=1
    # 补充 picolibc/newlib 标准库头文件路径（GCC 通过 -specs=picolibc.specs 隐式包含，clangd 被移除后需要手动加）
    - -ID:/Code/1-github-code/zephyr-sdk-0.17.2/arm-zephyr-eabi/arm-zephyr-eabi/include

# 诊断配置：抑制一些在嵌入式/Zephyr 代码中常见的误报
Diagnostics:
  Suppress:
    # 嵌入式代码中常见的 volatile 访问模式
    - unused-macros
    - missing-field-initializers
  ClangTidy:
    Remove:
      # 嵌入式项目中不适用的检查
      - cppcoreguidelines-*
      - modernize-use-trailing-return-type
      - readability-named-parameter
      - bugprone-easily-swappable-parameters

# 索引配置
Index:
  Background: Build
